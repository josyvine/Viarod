<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Text Display Style -->
    <style name="TextAppearance.Viaro.Header" parent="android:TextAppearance.Material">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.Viaro.Title" parent="android:TextAppearance.Material">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.Viaro.Body" parent="android:TextAppearance.Material">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Viaro.Body.Large" parent="android:TextAppearance.Material">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Viaro.Caption" parent="android:TextAppearance.Material">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>
</resources>
