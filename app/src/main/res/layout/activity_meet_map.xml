<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- OSMDroid Map -->
    <org.osmdroid.views.MapView
        android:id="@+id/map_meet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Distance and status overlay at the top -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:backgroundTint="@color/surface"
        android:elevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tv_meet_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="P2P Meetup Room: Connecting..."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tv_meet_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Distance: --"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/secondary"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tv_meet_breadcrumb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tracking Breadcrumb Trails active"
                android:textSize="10sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Floating End Meetup Button -->
    <Button
        android:id="@+id/btn_end_meet"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:background="@drawable/bg_button"
        android:backgroundTint="@color/error"
        android:text="End Meetup"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        style="?android:attr/borderlessButtonStyle"/>

</RelativeLayout>
