<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- OSMDroid Map -->
    <org.osmdroid.views.MapView
        android:id="@+id/map_meet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Distance and status overlay at the top -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_top_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:backgroundTint="@color/surface"
        android:elevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tv_meet_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="P2P Meetup Room: Connecting..."
                android:textSize="14sp"
                android:textColor="#E2E8F0"/>

            <TextView
                android:id="@+id/tv_meet_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Distance: --"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#2DD4BF"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tv_meet_guidance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Directions: Waiting for signal..."
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#60A5FA"
                android:layout_marginTop="6dp"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tv_meet_breadcrumb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tracking Breadcrumb Trails active"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Minimized GNSS Status Floating Card (Visually non-obstructive) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_gnss_minimized"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/card_top_status"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:backgroundTint="#CC1E293B"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_gnss_minimized_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡 0/0 Sats | Avg: 0 dB"
                android:textColor="#F8FAFC"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <!-- Maximize Button (Expands the full GNSS view again) -->
            <ImageButton
                android:id="@+id/btn_gnss_maximize"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/explore_24px"
                android:rotation="180"
                android:tint="#38BDF8"
                android:scaleType="centerInside"
                android:contentDescription="Maximize HUD" />

            <View
                android:layout_width="4dp"
                android:layout_height="1dp" />

            <!-- Close Button (Closes GNSS status tracking completely) -->
            <ImageButton
                android:id="@+id/btn_gnss_minimized_close"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/close_24px"
                android:tint="#EF4444"
                android:scaleType="centerInside"
                android:contentDescription="Close HUD" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom Action Row: Share Location Toggle, Map Explore Reset, GNSS Monitor, and GPS Location -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:layout_margin="24dp"
        android:gravity="center_vertical">

        <!-- Share Location Icon Toggle Button (Live state starts as Green #22C55E) -->
        <ImageButton
            android:id="@+id/btn_share_location"
            android:layout_width="@dimen/button_height"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/bg_button"
            android:backgroundTint="#22C55E"
            android:src="@drawable/share_location_24px"
            android:contentDescription="Share Location"
            android:scaleType="centerInside" />

        <!-- Spacer to push navigation/utility tools to the right-hand side -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Explore Compass Button (Reset Map Orientation to North) -->
        <ImageButton
            android:id="@+id/btn_explore"
            android:layout_width="@dimen/button_height"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/bg_button"
            android:backgroundTint="@color/surface"
            android:src="@drawable/explore_24px"
            android:contentDescription="Reset to North"
            android:scaleType="centerInside" />

        <!-- Fixed Spacer -->
        <View
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <!-- GNSS Diagnostic Monitor Toggle Button -->
        <ImageButton
            android:id="@+id/btn_gnss"
            android:layout_width="@dimen/button_height"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/bg_button"
            android:backgroundTint="@color/surface"
            android:src="@drawable/satellite_alt_24px"
            android:contentDescription="GNSS Diagnostics"
            android:scaleType="centerInside" />

        <!-- Fixed Spacer -->
        <View
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <!-- GPS Location Button -->
        <ImageButton
            android:id="@+id/btn_my_location"
            android:layout_width="@dimen/button_height"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/bg_button"
            android:backgroundTint="@color/surface"
            android:src="@drawable/ic_my_location"
            android:contentDescription="My Location"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- FULL SCREEN SEMI-TRANSPARENT GNSS MONITOR OVERLAY -->
    <RelativeLayout
        android:id="@+id/layout_gnss_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E60F172A"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <!-- Top Header Panel -->
        <RelativeLayout
            android:id="@+id/layout_gnss_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:background="#1F1E293B">

            <ImageView
                android:id="@+id/iv_gnss_logo"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/satellite_alt_24px"
                android:tint="#38BDF8"
                android:layout_centerVertical="true"
                android:contentDescription="GNSS Status Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/iv_gnss_logo"
                android:layout_marginStart="12dp"
                android:text="GNSS Diagnostics"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"/>

            <!-- Action buttons: Minimize and Close -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <!-- Minimize Button -->
                <ImageButton
                    android:id="@+id/btn_gnss_minimize"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/minimize_24px"
                    android:tint="#94A3B8"
                    android:scaleType="centerInside"
                    android:contentDescription="Minimize Overlay" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <!-- Close Button -->
                <ImageButton
                    android:id="@+id/btn_gnss_close"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/close_24px"
                    android:tint="#EF4444"
                    android:scaleType="centerInside"
                    android:contentDescription="Close Overlay" />

            </LinearLayout>
        </RelativeLayout>

        <!-- Main Scrollable Diagnostic Content Panel -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/layout_gnss_header"
            android:padding="20dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Stats summary block -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#261E293B"
                    app:cardCornerRadius="12dp"
                    android:elevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tv_gnss_sats_count"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Active Satellites: 0 used / 0 in view"
                            android:textColor="#F8FAFC"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_gnss_hardware_precision"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Precision Mode: Single-Band Tracking"
                            android:textColor="#38BDF8"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_gnss_accuracy"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Error Threshold: Horizontal ±--m | Vertical ±--m"
                            android:textColor="#94A3B8"
                            android:textSize="13sp" />

                        <!-- Horizontal Separator Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#1E293B"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:id="@+id/tv_gnss_signal_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Signal Strength Quality (Average)"
                            android:textColor="#94A3B8"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_gnss_signal_strength"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0.0 dB-Hz (No Lock)"
                            android:textColor="#F8FAFC"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <!-- Average strength signal bar -->
                        <ProgressBar
                            android:id="@+id/bar_gnss_signal_avg"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="8dp"
                            android:max="45"
                            android:progress="0"
                            android:progressDrawable="@android:color/white" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Actionable tips dialog container -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_gnss_tip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#1F3B4F52"
                    app:cardCornerRadius="12dp"
                    android:elevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_gnss_tip"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Tip: Acquiring satellite signals... If indoors, step near a window to establish a line-of-sight location fix."
                            android:textColor="#2DD4BF"
                            android:textSize="13sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Satellites List Block -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Constellation Signal Stream"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="true" />

                <!-- Container where satellite rows are programmatically loaded -->
                <LinearLayout
                    android:id="@+id/layout_satellite_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="40dp" />

            </LinearLayout>
        </ScrollView>
    </RelativeLayout>

</RelativeLayout>