<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- OSMDroid Map -->
    <org.osmdroid.views.MapView
        android:id="@+id/map_meet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Distance and status overlay at the top -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:backgroundTint="@color/surface"
        android:elevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tv_meet_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="P2P Meetup Room: Connecting..."
                android:textSize="14sp"
                android:textColor="#E2E8F0"/>

            <TextView
                android:id="@+id/tv_meet_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Distance: --"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#2DD4BF"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/tv_meet_guidance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Directions: Waiting for signal..."
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#60A5FA"
                android:layout_marginTop="6dp"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tv_meet_breadcrumb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tracking Breadcrumb Trails active"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom Action Row: End Meetup and GPS current position -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:layout_margin="24dp"
        android:gravity="center_vertical">

        <!-- End Meetup Button -->
        <Button
            android:id="@+id/btn_end_meet"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:background="@drawable/bg_button"
            android:backgroundTint="@color/error"
            android:text="End Meetup"
            android:drawableStart="@drawable/ic_close"
            android:drawablePadding="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            style="?android:attr/borderlessButtonStyle"/>

        <!-- Spacer -->
        <View
            android:layout_width="16dp"
            android:layout_height="1dp" />

        <!-- GPS Location Button -->
        <ImageButton
            android:id="@+id/btn_my_location"
            android:layout_width="@dimen/button_height"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/bg_button"
            android:backgroundTint="@color/surface"
            android:src="@drawable/ic_my_location"
            android:contentDescription="My Location"
            android:scaleType="centerInside" />
    </LinearLayout>

</RelativeLayout>
