<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Meet a Friend"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginTop="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Track each other's live coordinates in real-time. Share a private code to establish a link."
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp"/>

    <!-- Section 1: Create a Room -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:backgroundTint="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option A: Create a Room"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/secondary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generate a unique passcode to share with your friend."
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btn_create_room"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:background="@drawable/bg_button"
                android:text="Create New Room"
                android:textColor="@color/white"
                android:textStyle="bold"
                style="?android:attr/borderlessButtonStyle"/>

            <!-- Generated code container -->
            <LinearLayout
                android:id="@+id/layout_generated_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR ROOM CODE:"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_room_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--- ---"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/secondary"
                    android:layout_marginTop="4dp"
                    android:letterSpacing="0.1"/>

                <Button
                    android:id="@+id/btn_share_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Share Code"
                    android:textColor="@color/text_primary"
                    style="?android:attr/borderlessButtonStyle"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Section 2: Join a Room -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Option B: Join a Room"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_variant"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter the 6-digit code shared by your friend."
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/et_room_code"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_search"
                android:hint="e.g. 123456"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="6"
                android:letterSpacing="0.2"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btn_join_room"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:background="@drawable/bg_button"
                android:text="Join Room"
                android:textColor="@color/white"
                android:textStyle="bold"
                style="?android:attr/borderlessButtonStyle"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
