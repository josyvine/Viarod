<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Bottom Sheet handle indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/border_color"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_bs_bus_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="City Express 45"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"/>

    <TextView
        android:id="@+id/tv_bs_bus_route"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Route: Central -> Airport"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"/>

    <!-- Stats Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <!-- Speed Indicator -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:layout_marginEnd="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_speed"
                android:tint="@color/secondary"
                android:layout_marginEnd="8dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPEED"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tv_bs_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45 km/h"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ETA Indicator -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:layout_marginStart="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_eta"
                android:tint="@color/primary_variant"
                android:layout_marginEnd="8dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ETA"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tv_bs_eta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12 min"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btn_bs_track_live"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:background="@drawable/bg_button"
        android:text="Track Live / Focus Path"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        style="?android:attr/borderlessButtonStyle"/>

</LinearLayout>
