<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- OSMDroid Map -->
    <org.osmdroid.views.MapView
        android:id="@+id/map_track_bus"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top Search Header Layout -->
    <LinearLayout
        android:id="@+id/search_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_search"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:elevation="6dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search"
                android:tint="@color/text_secondary"
                android:layout_marginEnd="12dp"/>

            <EditText
                android:id="@+id/et_search_destination"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search destination..."
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text_primary"
                android:inputType="text"
                android:textSize="16sp"
                android:imeOptions="actionSearch"/>

            <ImageView
                android:id="@+id/btn_clear_search"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close"
                android:tint="@color/text_secondary"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Search Suggestions RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_search_suggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card"
            android:elevation="6dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Bottom Horizontal Scroll Menu -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:clipToPadding="false"
        android:layout_marginBottom="16dp"
        android:scrollbars="none"/>

</RelativeLayout>
